# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=dicom_viewer_desktop

# Orthanc Configuration
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=orthanc
ORTHANC_DICOMWEB_ROOT=/dicom-web
ORTHANC_STORAGE_PATH=./data/orthanc/storage

# Session Configuration
SESSION_LIFETIME=28800
SESSION_SECURE=false
SESSION_NAME=DICOM_DESKTOP_SESSION

# Application Configuration
APP_ENV=production
APP_URL=http://localhost:8080
APP_NAME="Hospital DICOM Viewer Pro - Desktop"
APP_VERSION=2.0.0-desktop
APP_TIMEZONE=Asia/Kolkata

# Security
BCRYPT_COST=12

# Logging - Enhanced for desktop debugging
LOG_LEVEL=debug
LOG_PATH=./data/logs
DEBUG_MODE=true
DEBUG_SQL=true
DEBUG_ORTHANC=true

# Google Drive Configuration (Optional - works when internet available)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_DRIVE_FOLDER=DICOM_Viewer_Backups

# FTP Configuration (Optional - works when network available)
FTP_HOST=
FTP_USERNAME=
FTP_PASSWORD=
FTP_PORT=21
FTP_PATH=/public_html/dicom_viewer/
FTP_PASSIVE=true

# Sync Configuration
SYNC_ENABLED=true
SYNC_INTERVAL=120
HOSPITAL_DATA_PATH=
MONITORING_ENABLED=false

# Backup Configuration (works offline - stores locally)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_TIME=02:00
BACKUP_RETENTION_DAYS=30
BACKUP_LOCAL_PATH=./data/backups

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Desktop Mode Settings
DESKTOP_MODE=true
OFFLINE_MODE_ENABLED=true
AUTO_START_ORTHANC=true
