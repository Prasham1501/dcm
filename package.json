{
    "name": "mediview",
    "version": "1.0.0",
    "description": "Mediview - Professional Medical Imaging Desktop Application",
    "main": "main.js",
    "scripts": {
        "start": "concurrently \"cd www && npm run dev\" \"electron .\"",
        "dev": "concurrently \"cd www && npm run dev\" \"electron .\"",
        "setup": "npm install && cd www && npm install && npm run build",
        "postinstall": "cd www && npm install",
        "build:react": "cd www && npm run build",
        "build:win": "npm run build:react && electron-builder --win",
        "build:quick": "electron-builder --win",
        "pack": "electron-builder --dir"
    },
    "author": "Mediview Team",
    "license": "MIT",
    "devDependencies": {
        "concurrently": "^8.2.2",
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    },
    "build": {
        "appId": "com.mediview.viewer",
        "productName": "Mediview",
        "icon": "icon.ico",
        "directories": {
            "output": "installer-output",
            "app": "."
        },
        "files": [
            "main.js",
            "preload.js",
            "splash.html",
            "icon.ico",
            "favicon.jpeg",
            "logo.png",
            "logo-dark.png",
            "package.json",
            "eng.traineddata"
        ],
        "extraResources": [
            {
                "from": "mysql",
                "to": "mysql",
                "filter": [
                    "bin/mysqld.exe",
                    "bin/mysql.exe",
                    "bin/mysql_install_db.exe",
                    "bin/my_print_defaults.exe",
                    "bin/resolveip.exe",
                    "bin/mysqladmin.exe",
                    "bin/*.dll",
                    "share/**/*",
                    "lib/**/*"
                ]
            },
            {
                "from": "orthanc",
                "to": "orthanc",
                "filter": [
                    "**/*"
                ]
            },
            {
                "from": "www/dist",
                "to": "www/dist",
                "filter": [
                    "**/*"
                ]
            },
            {
                "from": "www/database/migrations",
                "to": "www/database/migrations",
                "filter": [
                    "*.sql"
                ]
            },
            {
                "from": "orthanc-config",
                "to": "orthanc-config",
                "filter": [
                    "*.lua",
                    "*.json"
                ]
            }
        ],
        "win": {
            "icon": "icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "perMachine": true,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Mediview",
            "installerIcon": "icon.ico",
            "uninstallerIcon": "icon.ico",
            "installerHeaderIcon": "icon.ico",
            "deleteAppDataOnUninstall": false,
            "runAfterFinish": true
        },
        "compression": "normal"
    },
    "dependencies": {
        "dicom-parser": "^1.8.21",
        "tesseract.js": "^5.1.1"
    }
}
