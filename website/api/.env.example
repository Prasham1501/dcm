APP_ENV=production
APP_URL=https://yourdomain.com

DB_HOST=localhost
DB_NAME=mediview
DB_USER=mediview_user
DB_PASS=change_this_password

# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change_this_to_a_random_64_char_hex_string

# Your own email (used to create the super-admin on first setup)
SUPER_ADMIN_EMAIL=you@yourdomain.com
