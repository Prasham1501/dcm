{
  "Name": "Hospital_DICOM_Server",
  "HttpPort": 8042,
  "RemoteAccessAllowed": true,
  "DicomPort": 4242,
  "DicomServerEnabled": true,
  "DicomAet": "HOSPITAL_ORTHANC",
  "DicomCheckCalledAet": false,
  "AuthenticationEnabled": true,
  "RegisteredUsers": {
    "orthanc": "orthanc",
    "admin": "admin123"
  },
  "StorageDirectory": "C:\\Orthanc\\OrthancStorage",
  "IndexDirectory": "C:\\Orthanc\\OrthancDatabase",
  "HttpsCertificate": "",
  "SslEnabled": false,
  "SslCertificate": "",
  "HttpsPort": 8043,
  "HttpHeaders": {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
    "Access-Control-Allow-Headers": "Content-Type, Authorization, X-Requested-With",
    "Access-Control-Allow-Credentials": "true",
    "Access-Control-Max-Age": "86400"
  },
  "HttpCompressionEnabled": true,
  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/",
    "EnableWado": true,
    "WadoRoot": "/wado/",
    "Ssl": false,
    "QidoCaseSensitive": false,
    "Host": "0.0.0.0",
    "StowMaxInstances": 100,
    "StowMaxPatients": 100
  },
  "Plugins": [
    "C:\\Orthanc\\Plugins"
  ],
  "HttpVerbose": false,
  "DicomVerbose": false,
  "SaveJobs": true,
  "JobsHistorySize": 1000,
  "MaximumStorageSize": 0,
  "MaximumPatientCount": 0,
  "MaximumStorageMode": "Recycle",
  "ConcurrentJobs": 4,
  "HttpTimeout": 60,
  "DicomScuTimeout": 10,
  "DicomScpTimeout": 30,
  "StableAge": 60,
  "StrictAetComparison": false,
  "MediaArchiveSize": 1,
  "EnableMediaArchive": true,
  "UnknownSopClassAccepted": true,
  "MemoryBufferSize": 128,
  "MaximumPduLength": 131072,
  "DicomThreadsCount": 4,
  "QueryRetrieveSize": 100,
  "IngestTranscodingOfUncompressed": true,
  "IngestTranscodingOfCompressed": true,
  "WorklistsServer": false,
  "OverwriteInstances": false,
  "ExecuteLuaEnabled": true,
  "LuaScripts": [
    "dicom-callbacks.lua"
  ],
  "PythonScript": "",
  "PythonVerbose": false,
  "LogExportedResources": true,
  "LogLevel": "default",
  "KeepAlive": true,
  "TcpNoDelay": true,
  "StorageAccessOnFind": "Always",
  "MetadataStorageType": "Default",
  "SynchronousCMove": false,
  "TranscodeDicomProtocol": true
}